<Window x:Class="GlassForge.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GlassForge" Height="490" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Foreground="White">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="GlassForge" FontSize="22" FontWeight="Bold"/>
        <TextBlock Grid.Row="1" x:Name="StatusText" FontSize="12"
                   Foreground="#888888" Margin="0,4,0,0"/>

        <!-- Taskbar Glass section -->
        <TextBlock Grid.Row="3" Text="Taskbar Glass"
                   FontSize="13" FontWeight="SemiBold"/>

        <!-- Enable effect checkbox -->
        <CheckBox Grid.Row="4" x:Name="EffectEnabled"
                  Content="Enable effect"
                  Foreground="#CCCCCC" FontSize="12"
                  Margin="0,8,0,0"/>

        <!-- Backdrop mode row -->
        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Backdrop"
                       FontSize="12" Foreground="#CCCCCC" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="BackdropMode"
                      FontSize="12" Padding="6,4"
                      Background="#2D2D2D" Foreground="#CCCCCC"
                      BorderBrush="#444444">
                <ComboBox.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2D2D2D"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#CCCCCC"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3D5A80"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#2D2D2D"/>
                </ComboBox.Resources>
                <ComboBoxItem Content="Acrylic" Tag="Acrylic"/>
                <ComboBoxItem Content="Blur" Tag="Blur"/>
                <ComboBoxItem Content="None" Tag="None"/>
            </ComboBox>
        </Grid>

        <!-- Opacity row -->
        <Grid Grid.Row="6" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Opacity"
                       FontSize="12" Foreground="#CCCCCC" VerticalAlignment="Center"/>
            <Slider Grid.Column="1" x:Name="OpacitySlider"
                    Minimum="0" Maximum="1" TickFrequency="0.05"
                    IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" x:Name="OpacityLabel"
                       FontSize="12" Foreground="#CCCCCC"
                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </Grid>

        <!-- System Capabilities section -->
        <TextBlock Grid.Row="8" Text="System Capabilities"
                   FontSize="13" FontWeight="SemiBold"/>

        <ItemsControl Grid.Row="10" x:Name="CapabilityList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                   FontSize="12" Foreground="#CCCCCC"/>
                        <TextBlock Grid.Column="1" Text="{Binding Status}"
                                   FontSize="12" Foreground="{Binding Color}"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
