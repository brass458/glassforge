<Window x:Class="GlassForge.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GlassForge Settings"
        Height="560" Width="800"
        MinHeight="480" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="GlassForge"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="#E0E0E0"/>
                <TextBlock x:Name="VersionLabel"
                           FontSize="12" Foreground="#888888"
                           VerticalAlignment="Bottom" Margin="8,0,0,2"/>
            </StackPanel>
        </Border>

        <!-- Content area — placeholder for v0.1.0 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <TextBlock Text="GlassForge v0.1.0"
                           FontSize="15" FontWeight="Medium"
                           Foreground="#CCCCCC" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="#888888" FontSize="13"
                           Text="Infrastructure initialized. Shell backend loaded. Use the tray icon to access settings."/>

                <Separator Margin="0,16" Background="#3A3A3A"/>

                <!-- Capability info -->
                <TextBlock Text="Detected Capabilities"
                           FontSize="13" FontWeight="Medium"
                           Foreground="#AAAAAA" Margin="0,0,0,8"/>
                <TextBlock x:Name="CapabilityInfo"
                           TextWrapping="Wrap" Foreground="#777777" FontSize="12"/>

                <Separator Margin="0,16" Background="#3A3A3A"/>

                <!-- Build info -->
                <TextBlock x:Name="BuildInfo"
                           TextWrapping="Wrap" Foreground="#666666" FontSize="11"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#252525" Padding="16,10">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Close to Tray"
                        Padding="12,6"
                        Background="#3A3A3A" Foreground="#CCCCCC"
                        BorderBrush="#505050"
                        Click="CloseToTray_Click"/>
                <TextBlock x:Name="StatusLabel"
                           VerticalAlignment="Center"
                           Foreground="#666666" FontSize="11"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
